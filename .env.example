# OpportuCI Environment Variables
# Copy to .env and fill in values

# Google AI (Gemini)
GEMINI_API_KEY=

# Google OAuth (for Sheets/Slides deliverables)
# Download credentials.json from Google Cloud Console

# Database (if running locally without Docker)
DATABASE_URL=postgres://opportunci_user:password@localhost:5432/opportunci

# Redis
REDIS_URL=redis://localhost:6379/0
